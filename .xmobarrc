Config { font = "xft:Sans-9:bold"
       , bgColor = "black"
       , fgColor = "grey"
       , position = Top
       , lowerOnStart = False
       , commands = [ Run Weather "SBSP" ["-t","<station>: <tempC>C","-L","16","-H","27","--normal","gray","--high","red","--low","lightblue"] 36000
                    , Run Network "eth1" ["-L","0","-H","220","--normal","gray","--high","red"] 10
                    , Run Network "wlan2" ["-L","0","-H","220","--normal","gray","--high","red"] 10
                    , Run Cpu ["-L","3","-H","50","--normal","gray","--high","red"] 10
                    , Run Memory ["-t","Mem: <usedratio>%"] 10
                    , Run Swap [] 10
                    , Run Com "uname" ["-s","-r"] "" 36000
, Run Date "%a %b %_d %Y %H:%M:%S" "date" 10
, Run StdinReader
                    ]
       , sepChar = "%"
       , alignSep = "}{"
       , template = "%StdinReader% }{ %cpu% | %memory% * %swap% | %eth1% - %wlan2% | <fc=#ee9a00>%date%</fc>| %SBSP%"
}
