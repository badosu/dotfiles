Config { font = "xft:Anonymous Pro Bold:pixelsize=12"
       , bgColor = "black"
       , fgColor = "grey"
       , position = Top
       , lowerOnStart = False
       , commands = [ Run Network "eth0" ["-L","0","-H","220","--normal","gray","--high","red"] 10
                    , Run Network "wlan0" ["-L","0","-H","220","--normal","gray","--high","red"] 10
                    , Run Cpu ["-L","3","-H","50","--normal","gray","--high","red"] 10
                    , Run Memory ["-t","Mem: <usedratio>%"] 10
                    , Run Battery ["-L","25","-H","75","--normal","gray","--high","blue","--low","red","-t","Batt: <left>%"] 10
                    , Run Swap [] 10
                    , Run Com "uname" ["-s","-r"] "" 36000
, Run Date "%a %b %_d %Y %H:%M:%S" "date" 10
, Run StdinReader
                    ]
       , sepChar = "%"
       , alignSep = "}{"
       , template = "%StdinReader% }{ %cpu% | %memory% * %swap% | %eth0% - %wlan0% | <fc=#ee9a00>%date%</fc> | %battery%"
}
