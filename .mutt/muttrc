set editor = "vim"
auto_view text/html text/enriched application/x-gunzip application/x-tar-gz

set config_charset=utf-8
#set signature="iconv -f utf-8 ~/.signature |"
set locale=`echo "${LC_ALL:-${LC_TIME:-${LANG}}}"`

set mail_check = 120
set timeout = 300
set imap_keepalive = 300
set header_cache=~/.mutt/cache/headers
set message_cachedir=~/.mutt/cache/bodies
set certificate_file=~/.mutt/certificates
set move = no
set include
set sort = 'threads'
set auto_tag = yes
hdr_order Date From To Cc

source ~/.mutt/bindings.muttrc
source ~/.mutt/theme.muttrc
source ~/.mutt/accounts.muttrc

set sendmail="/usr/bin/sendmail -oi -oem"

set send_charset="utf-8"
set assumed_charset="iso-8859-1"

set query_command = "abook --mutt-query '%s'"
macro generic,index,pager \ca "<shell-escape>abook<return>" "launch abook"
macro index,pager a "<pipe-message>abook --add-email<return>" "add the sender address to abook"

set display_filter="sed -e '/\\[-- Autoview using.*--\\]/d'"

set sidebar_visible=no

set pager_index_lines = 5
