!URxvt resources
!
URxvt.depth: 32
URxvt.background: rgba:1111/1111/1111/dddd
URxvt.scrollBar: off
URxvt.font: xft:Anonymous Pro:pixelsize=14
URxvt*foreground: grey75

!oblack
